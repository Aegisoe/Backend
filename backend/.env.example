# =============================================
# AEGISOE Backend — Environment Variables
# =============================================
# Copy this file to .env and fill in the values

# GitHub Webhook Secret
# Set this to any random string — must match GitHub webhook settings
# Example: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# CRE Trigger URL (dari Dev 2 setelah workflow deployed)
# Saat development: biarkan kosong atau pakai placeholder untuk mock mode
CRE_TRIGGER_URL=https://your-cre-endpoint/scan

# OpenAI API Key (untuk LLM classification — Step 3)
# Jika tidak di-set, backend pakai fallback deterministic mode
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Server Port (optional, default 3000)
PORT=3000

# Vault URL (HashiCorp Vault untuk production)
VAULT_URL=http://localhost:8200
