# =============================================
# AEGISOE Backend — Environment Variables
# =============================================
# Copy this file to .env and fill in the values

# GitHub Webhook Secret
# Set this to any random string — must match GitHub webhook settings
# Example: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# CRE Trigger URL (dari Dev 2 setelah workflow deployed)
# Saat development: biarkan kosong atau pakai placeholder untuk mock mode
CRE_TRIGGER_URL=https://your-cre-endpoint/scan

# Groq API Key (untuk LLM classification — Step 3)
# Jika tidak di-set, backend pakai fallback deterministic mode
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Operator Private Key (untuk submit on-chain tx ke AegisoeRegistry Sepolia)
# Private key dari address: 0x6b75074B52d17A1FD101ED984605e3EF2EAB5e57
# JANGAN commit file .env!
OPERATOR_PRIVATE_KEY=0x...

# Sepolia RPC URL (opsional, default pakai public node)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# CRE Callback Secret — harus sama dengan BACKEND_CALLBACK_SECRET di CRE secrets
# Generate: openssl rand -hex 32
CRE_CALLBACK_SECRET=your_cre_callback_secret_here

# Server Port (optional, default 3000)
PORT=3000
