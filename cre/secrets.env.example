# ══════════════════════════════════════════════════════════════════
# AEGISOE CRE — Secrets Configuration
# Semua secret ini tersimpan encrypted di CRE secret store.
# TIDAK ADA yang masuk ke repo — file ini hanya contoh.
# ══════════════════════════════════════════════════════════════════

# GitHub Personal Access Token (untuk fetch commit diff)
# Scope yang dibutuhkan: repo (read)
# Generate: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI Admin Key (untuk generate/revoke API keys)
# Scope: Organization admin
# Generate: https://platform.openai.com/api-keys
OPENAI_ADMIN_KEY=sk-admin-xxxxxxxxxxxxxxxxxxxx

# HashiCorp Vault Admin Token
# Untuk update secret setelah rotasi
VAULT_ADMIN_TOKEN=hvs.xxxxxxxxxxxxxxxxxxxxxxxxx

# Wallet Private Key (untuk sign on-chain transactions)
# Wallet ini HARUS sudah di-authorize sebagai operator di AegisoeRegistry
# CRE_OPERATOR_ADDRESS=0x6b75074B52d17A1FD101ED984605e3EF2EAB5e57
CONTRACT_PRIVATE_KEY=0x_your_private_key_here

# Sepolia RPC URL
# Bisa pakai: Alchemy, Infura, atau public RPC
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
